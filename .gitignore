# Environment variables and secrets
# NEVER track .env. It holds live API keys. A .gitignore rule does NOT apply to a
# file that is already tracked, which is how real credentials reached this public
# repo before. If .env ever reappears in `git status` as tracked, run:
#     git rm --cached .env
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
